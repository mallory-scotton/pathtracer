///////////////////////////////////////////////////////////////////////////////
// Header guard
///////////////////////////////////////////////////////////////////////////////
#pragma once

///////////////////////////////////////////////////////////////////////////////
// Dependencies
///////////////////////////////////////////////////////////////////////////////
#include "Maths/Vec3.hpp"

///////////////////////////////////////////////////////////////////////////////
// Namespace Ray
///////////////////////////////////////////////////////////////////////////////
namespace Ray
{

///////////////////////////////////////////////////////////////////////////////
template <typename T>
Vec3<T>::Vec3(void)
    : x(static_cast<T>(0))
    , y(static_cast<T>(0))
    , z(static_cast<T>(0))
{}

///////////////////////////////////////////////////////////////////////////////
template <typename T>
Vec3<T>::Vec3(const T& all)
    : x(all)
    , y(all)
    , z(all)
{}

///////////////////////////////////////////////////////////////////////////////
template <typename T>
Vec3<T>::Vec3(const T& x, const T& y, const T& z)
    : x(x)
    , y(y)
    , z(z)
{}

} // namespace Ray
